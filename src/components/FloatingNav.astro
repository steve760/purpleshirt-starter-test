---
/**
 * Floating section nav — appears top-right on wide screens only.
 * Collapsed by default: a dark pill showing "NN / NN — Current Section ☰".
 * Click the pill to expand the full list; click outside (or Escape) to collapse.
 * Links jump to the section IDs set by SectionRenderer (ps-{filename}).
 */
interface NavItem {
  id: string;
  label: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
const total = String(items.length).padStart(2, '0');
const firstLabel = items[0]?.label ?? '';
---

{items.length > 0 && (
  <nav class="ps-floatnav" data-collapsed aria-label="Page sections">
    <button class="ps-floatnav-toggle" type="button" aria-expanded="false" aria-controls="ps-floatnav-panel">
      <span class="ps-floatnav-toggle-current">
        <span class="ps-floatnav-toggle-num">01</span>
        <span class="ps-floatnav-toggle-sep">/</span>
        <span class="ps-floatnav-toggle-total">{total}</span>
      </span>
      <span class="ps-floatnav-toggle-label">{firstLabel}</span>
      <span class="ps-floatnav-toggle-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 4h10M2 7h10M2 10h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
    </button>
    <div class="ps-floatnav-panel" id="ps-floatnav-panel">
      <div class="ps-floatnav-title">On this page</div>
      <ul class="ps-floatnav-list">
        {items.map((item, i) => (
          <li>
            <a href={`#${item.id}`} data-floatnav-target={item.id}>
              <span class="ps-floatnav-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="ps-floatnav-label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<script>
  function initFloatingNav() {
    const nav = document.querySelector<HTMLElement>('.ps-floatnav');
    if (!nav) return;

    const toggle = nav.querySelector<HTMLButtonElement>('.ps-floatnav-toggle');
    const toggleNum = nav.querySelector<HTMLElement>('.ps-floatnav-toggle-num');
    const toggleLabel = nav.querySelector<HTMLElement>('.ps-floatnav-toggle-label');
    const links = nav.querySelectorAll<HTMLAnchorElement>('[data-floatnav-target]');

    type Section = { id: string; el: HTMLElement; link: HTMLAnchorElement; index: number; label: string };
    const sections: Section[] = [];
    links.forEach((link, i) => {
      const id = link.dataset.floatnavTarget!;
      const el = document.getElementById(id);
      if (!el) return;
      const label = link.querySelector<HTMLElement>('.ps-floatnav-label')?.textContent?.trim() || '';
      sections.push({ id, el, link, index: i + 1, label });
    });

    function setExpanded(expanded: boolean) {
      if (expanded) {
        nav!.removeAttribute('data-collapsed');
        toggle?.setAttribute('aria-expanded', 'true');
      } else {
        nav!.setAttribute('data-collapsed', '');
        toggle?.setAttribute('aria-expanded', 'false');
      }
    }

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      setExpanded(nav.hasAttribute('data-collapsed'));
    });

    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target as Node)) setExpanded(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setExpanded(false);
    });

    nav.querySelectorAll<HTMLAnchorElement>('.ps-floatnav-list a').forEach((a) => {
      a.addEventListener('click', () => setExpanded(false));
    });

    function updateActive() {
      const anchorY = window.innerHeight * 0.4;
      let current: Section | null = null;
      for (const s of sections) {
        const r = s.el.getBoundingClientRect();
        if (r.top <= anchorY && r.bottom > anchorY) { current = s; break; }
      }
      // Fallback: nearest section above the anchor
      if (!current) {
        let best: Section | null = null;
        let bestTop = -Infinity;
        for (const s of sections) {
          const top = s.el.getBoundingClientRect().top;
          if (top <= anchorY && top > bestTop) { bestTop = top; best = s; }
        }
        current = best ?? sections[0] ?? null;
      }
      if (!current) return;
      sections.forEach((s) => s.link.classList.toggle('active', s === current));
      if (toggleNum) toggleNum.textContent = String(current.index).padStart(2, '0');
      if (toggleLabel) toggleLabel.textContent = current.label;
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', updateActive, { passive: true });
    updateActive();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingNav);
  } else {
    initFloatingNav();
  }
</script>
