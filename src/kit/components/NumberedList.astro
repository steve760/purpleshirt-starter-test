---
interface ListItem {
  title: string;
  description: string;
}

interface Props {
  sectionNumber?: string;
  heading: string;
  subtitle?: string;
  items: ListItem[];
  dark?: boolean;
}

const { sectionNumber, heading, subtitle, items, dark = false } = Astro.props;
const twoCol = items.length >= 6;
const rows = Math.ceil(items.length / 2);
---

<section class:list={['ps-section', 'ps-numlist-section', { 'ps-numlist-dark': dark }]}>
  <div class="ps-numlist-header">
    {sectionNumber && <div class="ps-numlist-section-num">{sectionNumber}</div>}
    <h2>{heading}</h2>
  </div>
  {subtitle && <p class="ps-numlist-subtitle">{subtitle}</p>}

  <ol
    class:list={['ps-numlist', { 'ps-numlist-twocol': twoCol }]}
    style={twoCol ? `--ps-numlist-rows: ${rows};` : undefined}
  >
    {items.map((item, i) => (
      <li class:list={['ps-numlist-item', { 'ps-numlist-col-end': twoCol && i === rows - 1 }]}>
        <div class="ps-numlist-num">{String(i + 1).padStart(2, '0')}</div>
        <div class="ps-numlist-content">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      </li>
    ))}
  </ol>
</section>
