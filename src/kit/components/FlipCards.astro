---
interface Card {
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
}

interface Props {
  sectionNumber?: string;
  heading: string;
  subtitle?: string;
  cardsPerPage?: number;
  cards: Card[];
  dark?: boolean;
}

const {
  sectionNumber,
  heading,
  subtitle,
  cardsPerPage = 3,
  cards,
  dark = false,
} = Astro.props;

const id = `flipcards-${Math.random().toString(36).substring(2, 8)}`;
const totalPages = Math.ceil(cards.length / cardsPerPage);

// Deterministic per-card float params so server & client match
function floatParams(i: number) {
  const dur = 4 + ((i * 37) % 40) / 10; // 4.0s–8.0s
  const delay = ((i * 53) % 40) / 10;   // 0s–4s
  const amp = 18 + ((i * 71) % 16);     // 18px–33px
  return { dur, delay, amp };
}
---

<section class:list={['ps-section', 'ps-flipcards-section', { 'ps-flipcards-dark': dark }]} data-flipcards-id={id}>
  <div class="ps-flipcards-header">
    {sectionNumber && <div class="ps-flipcards-section-num">{sectionNumber}</div>}
    <h2>{heading}</h2>
  </div>
  {subtitle && <p class="ps-flipcards-subtitle">{subtitle}</p>}

  <div class="ps-flipcards-viewport">
    <div class="ps-flipcards-track" style={`--cards-per-page: ${cardsPerPage};`}>
      {cards.map((card, i) => {
        const { dur, delay, amp } = floatParams(i);
        const page = Math.floor(i / cardsPerPage);
        return (
          <div
            class="ps-flipcards-card"
            data-index={i}
            data-page={page}
            style={`--float-dur: ${dur}s; --float-delay: ${delay}s; --float-amp: ${amp}px;`}
          >
            <div class="ps-flipcards-inner">
              <div class="ps-flipcards-face ps-flipcards-front">
                <div
                  class="ps-flipcards-image"
                  style={`background-image: url(${card.image});`}
                  role="img"
                  aria-label={card.imageAlt || card.title}
                ></div>
                <div class="ps-flipcards-flipicon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="ps-flipcards-front-title">{card.title}</div>
                <div class="ps-flipcards-hint" aria-hidden="true">Click to read more</div>
              </div>
              <div class="ps-flipcards-face ps-flipcards-back">
                <div class="ps-flipcards-flipicon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <h3>{card.title}</h3>
                <div class="ps-flipcards-description" set:html={card.description} />
                <div class="ps-flipcards-hint" aria-hidden="true">Click to flip back</div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  {totalPages > 1 && (
    <div class="ps-flipcards-controls">
      <button class="ps-flipcards-btn ps-flipcards-prev" aria-label="Previous page">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span class="ps-flipcards-counter">
        <span class="ps-flipcards-current">1</span> / {totalPages}
      </span>
      <button class="ps-flipcards-btn ps-flipcards-next" aria-label="Next page">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  )}
</section>

<script>
  function initFlipCards() {
    document.querySelectorAll<HTMLElement>('[data-flipcards-id]').forEach((section) => {
      const track = section.querySelector<HTMLElement>('.ps-flipcards-track');
      const cards = Array.from(section.querySelectorAll<HTMLElement>('.ps-flipcards-card'));
      const prev = section.querySelector<HTMLButtonElement>('.ps-flipcards-prev');
      const next = section.querySelector<HTMLButtonElement>('.ps-flipcards-next');
      const counter = section.querySelector<HTMLElement>('.ps-flipcards-current');
      if (!track || !cards.length) return;

      // Track recent swipe so card-flip clicks don't fire after a page swipe
      let lastSwipeAt = 0;

      // Click to flip (suppressed briefly after a swipe)
      cards.forEach((card) => {
        card.addEventListener('click', () => {
          if (Date.now() - lastSwipeAt < 400) return;
          card.classList.toggle('flipped');
        });
      });

      // Pagination
      const pages = new Set(cards.map(c => Number(c.dataset.page)));
      const totalPages = pages.size;
      let current = 0;

      function goTo(p: number) {
        current = ((p % totalPages) + totalPages) % totalPages;
        track!.style.setProperty('--current-page', String(current));
        if (counter) counter.textContent = String(current + 1);
        if (prev) prev.disabled = current === 0;
        if (next) next.disabled = current === totalPages - 1;
      }

      prev?.addEventListener('click', () => goTo(current - 1));
      next?.addEventListener('click', () => goTo(current + 1));

      // Touch swipe on the viewport for pagination
      const viewport = section.querySelector<HTMLElement>('.ps-flipcards-viewport');
      if (viewport && totalPages > 1) {
        let startX = 0;
        let startY = 0;
        let tracking = false;
        viewport.addEventListener('touchstart', (e) => {
          if (e.touches.length !== 1) return;
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
          tracking = true;
        }, { passive: true });
        viewport.addEventListener('touchend', (e) => {
          if (!tracking) return;
          tracking = false;
          const t = e.changedTouches[0];
          const dx = t.clientX - startX;
          const dy = t.clientY - startY;
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
            lastSwipeAt = Date.now();
            goTo(dx < 0 ? current + 1 : current - 1);
          }
        }, { passive: true });
      }

      goTo(0);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFlipCards);
  } else {
    initFlipCards();
  }
</script>
