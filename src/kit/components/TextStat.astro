---
interface Props {
  sectionNumber?: string;
  heading: string;
  columnOne: string;
  columnTwo: string;
  statValue: string;
  statLabel?: string;
  dark?: boolean;
}

const {
  sectionNumber,
  heading,
  columnOne,
  columnTwo,
  statValue,
  statLabel,
  dark = false,
} = Astro.props;
---

<section class:list={['ps-section', 'ps-textstat-section', { 'ps-textstat-dark': dark }]}>
  <div class="ps-textstat-header">
    {sectionNumber && <div class="ps-textstat-num">{sectionNumber}</div>}
    <h2>{heading}</h2>
  </div>
  <div class="ps-textstat-columns">
    <div class="ps-textstat-col" set:html={columnOne} />
    <div class="ps-textstat-col" set:html={columnTwo} />
    <div class="ps-textstat-stat">
      <div class="ps-textstat-circle">
        <div class="ps-textstat-value">{statValue}</div>
      </div>
      {statLabel && <div class="ps-textstat-stat-label">{statLabel}</div>}
    </div>
  </div>
</section>
