---
interface Props {
  logo: string;
  logoAlt?: string;
  downloadFile?: string;
  downloadLabel?: string;
}

const {
  logo,
  logoAlt = 'Client logo',
  downloadFile,
  downloadLabel = 'Download the report',
} = Astro.props;
---

<header class="ps-header">
  <div class="ps-header-inner">
    <div class="ps-header-left">
      <img class="ps-header-logo" src={logo} alt={logoAlt} />
    </div>
    {downloadFile && (
      <a class="ps-header-download" href={downloadFile} download>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 2v8M5 7l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 13h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        {downloadLabel}
      </a>
    )}
  </div>
</header>

<script>
  function initHeaderScroll() {
    const header = document.querySelector<HTMLElement>('.ps-header');
    if (!header) return;
    const update = () => {
      if (window.scrollY > 40) {
        header.classList.add('ps-header-scrolled');
      } else {
        header.classList.remove('ps-header-scrolled');
      }
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeaderScroll);
  } else {
    initHeaderScroll();
  }
</script>
